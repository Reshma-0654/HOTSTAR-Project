apiVersion: apps/v1
kind: Deployment
metadata:
  name: hotstar-app
spec:
  replicas: 2
  selector:
    matchLabels:
      app: hotstar
  template:
    metadata:
      labels:
        app: hotstar
    spec:
      containers:
      - name: hotstar
        image: reshma6540/hotstar:latest
        ports:
        - containerPort: 8080
